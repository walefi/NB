rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Services: public read (active only), admin write
    match /services/{serviceId} {
      allow read: if resource.data.isActive == true;
      allow write: if request.auth != null;
    }

    // Appointments: create with valid fields, admin read/write
    match /appointments/{appointmentId} {
      allow create: if request.resource.data.keys().hasAll([
        'serviceId', 'serviceName', 'servicePrice', 'serviceDuration',
        'clientName', 'clientPhone', 'paymentMethod',
        'date', 'time', 'status', 'createdAt'
      ])
      && request.resource.data.status == 'pending';

      allow read, update, delete: if request.auth != null;
    }

    // Settings: admin read/write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Notifications: admin read/write
    match /notifications/{notificationId} {
      allow create: if request.resource.data.keys().hasAll([
        'type', 'title', 'message', 'appointmentId',
        'clientName', 'clientPhone', 'date', 'time',
        'createdAt', 'read'
      ]);
      allow read, update, delete: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
